# ============================================
# Dropbox MCP Server Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- Option A: OAuth2 Refresh Token (RECOMMENDED for production) ---
# Get these from https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# --- Option B: Short-lived Access Token (quick testing only) ---
# Generate at https://www.dropbox.com/developers/apps → your app → Generate access token
# DROPBOX_ACCESS_TOKEN=

# --- Transport ---
# "stdio" for local use (Claude Desktop, Cursor)
# "sse" for remote/cloud deployment
TRANSPORT=stdio

# --- SSE settings (only needed when TRANSPORT=sse) ---
HOST=0.0.0.0
PORT=8080
